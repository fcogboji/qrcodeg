# Neon Postgres — copy from https://console.neon.tech → your project → Connection string
# Use the "psql" or "Prisma" format; include ?sslmode=require
#
# Example (replace user, password, host, db name):
# DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
# Optional: for Vercel/serverless, Neon provides a "pooled" URL (host contains "-pooler").
# Use pooled URL as DATABASE_URL for the app; run `prisma migrate deploy` locally or in CI
# with the direct (non-pooler) URL if migrations fail through the pooler.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Auth.js (next-auth v5) — required in production. Generate: openssl rand -base64 32
# If you change this, existing session cookies become invalid — clear site cookies or sign in again.
# You can also set NEXTAUTH_SECRET to the same value (some tools expect that name).
AUTH_SECRET="paste-a-long-random-string-here"
# Optional: canonical site URL (Vercel usually works with trustHost alone)
# AUTH_URL="https://your-domain.vercel.app"

# --- Widget (recommended: proxy on THIS app; browser loads /embed/widget-js only) ---
# Widget API origin (data-api-base + fetch target host). Must match your widget dashboard.
# NEXT_PUBLIC_WIDGET_ORIGIN="https://your-widget-app.vercel.app"
# Bot id + brand from widget dashboard (defaults exist in src/config/widget.ts)
# NEXT_PUBLIC_WIDGET_BOT_ID="..."
# NEXT_PUBLIC_WIDGET_BRAND="your-brand"
# Optional: if you need cache-bust on the script tag: NEXT_PUBLIC_WIDGET_EMBED_PATH="/embed/widget-js?v=5"

# Full URL to the real JS file to proxy (default: NEXT_PUBLIC_WIDGET_ORIGIN + /widget.js)
# WIDGET_SCRIPT_UPSTREAM_URL="https://your-widget-app.vercel.app/widget.js"

# If the widget host uses Vercel Deployment Protection, set the bypass secret so server fetch works:
# WIDGET_VERCEL_BYPASS_SECRET="..."   # or reuse VERCEL_AUTOMATION_BYPASS_SECRET
