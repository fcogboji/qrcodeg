# Neon Postgres — copy from https://console.neon.tech → your project → Connection string
# Use the "psql" or "Prisma" format; include ?sslmode=require
#
# Example (replace user, password, host, db name):
# DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
# Optional: for Vercel/serverless, Neon provides a "pooled" URL (host contains "-pooler").
# Use pooled URL as DATABASE_URL for the app; run `prisma migrate deploy` locally or in CI
# with the direct (non-pooler) URL if migrations fail through the pooler.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Clerk — https://dashboard.clerk.com → API Keys
# On Vercel: add BOTH to Project → Settings → Environment Variables for Production (and Preview if needed).
# Use live keys (pk_live_ / sk_live_) for production; test keys for local.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
#
# In Clerk Dashboard → Configure → Domains, add your Vercel URL (e.g. https://qrcodeg-alpha.vercel.app)
# and set Paths: Sign-in /sign-in, Sign-up /sign-up

# Optional: full URL to widget.js. Used by /embed/widget-js when proxying server-side.
# WIDGET_SCRIPT_UPSTREAM_URL="https://your-cdn.example.com/widget.js"

# If the widget host uses Vercel Deployment Protection, set the bypass secret so server fetch works:
# WIDGET_VERCEL_BYPASS_SECRET="..."   # or reuse VERCEL_AUTOMATION_BYPASS_SECRET

# Public origin for the widget (browser client-loader); defaults match layout.
# NEXT_PUBLIC_WIDGET_ORIGIN="https://your-project.vercel.app"
