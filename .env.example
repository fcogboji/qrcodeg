# Local SQLite (path relative to prisma/)
#DATABASE_URL="file:./dev.db"

# Docker Compose (see docker-compose.yml) uses a mounted volume, e.g.:
# DATABASE_URL="file:///app/data/prod.db"

# Managed production: PostgreSQL
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Optional: full URL to widget.js (default is the bundled Vercel widget). Used by /embed/widget-js proxy.
# WIDGET_SCRIPT_UPSTREAM_URL="https://your-cdn.example.com/widget.js"
